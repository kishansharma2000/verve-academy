---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Vervve Academy — Aviation Institute' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Vervve Academy trains the next generation of aviation professionals — from first flight to airline-ready." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,300;1,400;1,600&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="pt-[60px]">
    <slot />
  </body>
</html>

---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  schema?: object;
}

const { 
  title = 'Vervve Academy — Aviation Institute', 
  description = 'Vervve Academy trains the next generation of aviation professionals — from first flight to airline-ready.',
  image = '/og-default.jpg',
  canonicalURL = Astro.url.href
} = Astro.props;

const ogImage = new URL(image, Astro.site || Astro.url.origin).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0066CC" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Vervve Academy" />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Vervve Academy",
        "url": "https://verveacademy.com",
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": "https://verveacademy.com/?s={search_term_string}"
          },
          "query-input": "required name=search_term_string"
        }
      }
    </script>

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "EducationalOrganization",
        "name": "Vervve Academy",
        "description": "Aviation institute offering diploma and certification courses in airport management, cabin crew, and airline customer service.",
        "url": "https://verveacademy.com",
        "telephone": "+919620001901",
        "email": "enquiry@vervveacademy.com",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "No.520/432, Pyramid north square, 4th Floor, New airport road",
          "addressLocality": "Yelahanka, Bangalore",
          "addressRegion": "Karnataka",
          "postalCode": "562157",
          "addressCountry": "IN"
        },
        "areaServed": "IN",
        "sameAs": []
      }
    </script>
  </head>
  <body class="pt-[60px]">
    <slot />
  </body>
</html>

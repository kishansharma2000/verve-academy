---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  schema?: object;
}

const { 
  title = 'Vervve Academy — Aviation Institute', 
  description = 'Vervve Academy trains the next generation of aviation professionals — from first flight to airline-ready.',
  image = '/og-default.jpg',
  canonicalURL = Astro.url.href
} = Astro.props;

const ogImage = new URL(image, Astro.site || Astro.url.origin).href;
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0066CC" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="/Hero-mobile.webp" as="image" media="(max-width: 768px)" />
    <link rel="preload" href="/Hero-desktop.webp" as="image" media="(min-width: 769px)" />
    <link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700&display=swap" rel="stylesheet" /></noscript>
    <title>{title}</title>
    <script type="application/ld+json" defer>
      {
        "@context": "https://schema.org",
        "@type": "EducationalOrganization",
        "name": "Vervve Academy",
        "url": "https://verveacademy.com"
      }
    </script>
  </head>

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Vervve Academy" />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" defer>
      {
        "@context": "https://schema.org",
        "@type": "EducationalOrganization",
        "name": "Vervve Academy",
        "url": "https://verveacademy.com"
      }
    </script>
  </head>
  <body class="pt-[60px]">
    <slot />
  </body>
</html>

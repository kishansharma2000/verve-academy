---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';

const program = {
  title: 'Corporate Training',
  subtitle: 'Professional Development',
  overview: `Executive training programs designed for individuals with work experience who are aspiring towards more senior positions. These programs provide instruction in topics essential to managers and executives.`,
  trainingCategories: [
    {
      name: 'Soft Skills',
      skills: [
        'Assertiveness & Self-Confidence',
        'Communication Strategies',
        'Creative Problem Solving',
        'Team Building & Time Management',
        'Business Etiquettes',
        'Conflict & Stress Management',
        'Presentation Skills',
      ],
    },
    {
      name: 'Human Resources',
      skills: [
        'Employee On-boarding',
        'Talent Management',
        'Train the Trainer',
        'Workplace Diversity',
        'Hiring Strategies',
        'Interviewing Techniques',
        'HR Management',
      ],
    },
    {
      name: 'Customer Service & Sales',
      skills: [
        'Customer Service Excellence',
        'Customer Care',
        'Negotiation Skills',
        'Telephone Communication',
        'Call Handling Skills',
        'Sales & Merchandising',
      ],
    },
    {
      name: 'Administrative Skills',
      skills: [
        'Business Writing Skills',
        'Executive Secretarial Skills',
        'Social Media at Work',
        'Report Writing',
      ],
    },
  ],
  segments: [
    { title: 'Industry Specific', items: ['Retail', 'Healthcare', 'Finance', 'IT', 'Public Sector'] },
    { title: 'Function Specific', items: ['Technical', 'Quality', 'Compliance', 'Finance'] },
    { title: 'Role Specific', items: ['Entry Level', 'Manager', 'Team Leader', 'Leadership'] },
  ],
  benefits: [
    'Increased employee performance',
    'Stronger workforce',
    'Alignment with goals',
    'Boosts engagement',
    'Knowledge sharing',
    'Fosters innovation',
    'Improved processes',
  ],
};

const otherPrograms = [
  { name: 'Diploma in Airport Management', slug: 'diploma-in-airport-management' },
  { name: 'Diploma in Cabin Crew & Airport Ground Operations', slug: 'diploma-in-cabin-crew' },
  { name: 'Certification Course in Airline Customer Service', slug: 'certification-in-airline-customer-service' },
];
---

<Layout 
  title={`${program.title} | Vervve Academy`}
  description="Executive training programs designed for individuals aspiring towards senior management positions. Learn soft skills, HR, customer service & more."
>
  <Navbar />
  
  <main>
    <article class="bg-white">
      <header class="max-w-3xl mx-auto px-6 pt-16 pb-10">
        <a href="/#programs" class="inline-flex items-center gap-2 text-muted text-sm hover:text-ink transition-colors mb-8">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Programs
        </a>
        
        <div class="flex items-center gap-4 mb-6">
          <span class="text-[11px] font-medium uppercase tracking-widest text-muted">
            {program.subtitle}
          </span>
        </div>
        
        <h1 class="font-sans font-normal text-3xl md:text-4xl lg:text-5xl text-ink tracking-tight leading-[1.3] lg:leading-[1.3] mb-6">
          {program.title}
        </h1>
        
        <p class="text-muted text-lg leading-relaxed mb-8">
          {program.overview}
        </p>
      </header>

      <div class="max-w-3xl mx-auto px-6 pb-12">
        <div class="prose-program space-y-20">
          <section>
            <h2>Training Programs</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {program.trainingCategories.map((category) => (
                <div class="bg-off-white/50 rounded-xl p-5">
                  <h3 class="font-medium text-ink mb-3">{category.name}</h3>
                  <ul class="space-y-1">
                    {category.skills.map((skill) => (
                      <li class="text-muted text-sm">{skill}</li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </section>

          <section>
            <h2>Training Segments</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              {program.segments.map((segment) => (
                <div class="bg-off-white/50 rounded-xl p-5">
                  <h3 class="font-medium text-ink mb-3">{segment.title}</h3>
                  <ul class="space-y-1">
                    {segment.items.map((item) => (
                      <li class="text-muted text-sm">{item}</li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </section>

          <section>
            <h2>Key Benefits</h2>
            <ul>
              {program.benefits.map((benefit) => (
                <li>
                  <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{benefit}</span>
                </li>
              ))}
            </ul>
          </section>
        </div>
      </div>

      <div class="max-w-3xl mx-auto px-6 pb-16">
        <div class="bg-off-white/50 rounded-2xl p-6 sm:p-8 flex flex-col gap-6">
          <div>
            <h3 class="text-2xl font-semibold text-ink mb-1 sm:mb-2">Request Training</h3>
            <p class="text-muted text-sm">Contact us to discuss your organization's training needs.</p>
          </div>
          <a href="/#contact" class="self-start sm:self-end bg-aviation text-white text-base font-medium px-6 py-3 rounded-full hover:bg-aviation-light hover:text-aviation transition-colors">
            Get in Touch
          </a>
        </div>
      </div>
    </article>

    <section class="bg-off-white py-20 px-6">
      <div class="max-w-6xl mx-auto">
        <h2 class="font-sans font-normal text-2xl md:text-3xl text-ink tracking-tight leading-[1.4] mb-10">
          Other Programs
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {otherPrograms.map((p) => (
            <a href={`/programs/${p.slug}`} class="group">
              <article class="bg-white rounded-2xl overflow-hidden border border-border h-full flex flex-col">
                <div class="aspect-[16/10] bg-ink/5 flex items-center justify-center">
                  <svg class="w-10 h-10 text-aviation/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                  </svg>
                </div>
                <div class="p-6 flex flex-col flex-1">
                  <h3 class="font-sans font-medium text-base text-ink leading-snug mb-3 group-hover:text-muted transition-colors">
                    {p.name}
                  </h3>
                  <span class="text-sm text-muted mt-auto inline-flex items-center gap-1">
                    Learn more
                    <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </span>
                </div>
              </article>
            </a>
          ))}
        </div>
      </div>
    </section>

    <CTA />
  </main>

  <Footer />
</Layout>

<style>
  .prose-program :global(h2) {
    font-family: 'Figtree', system-ui, sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: #0A0A0A;
    margin-bottom: 1rem;
    line-height: 1.4;
  }

  .prose-program :global(h3) {
    font-family: 'Figtree', system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: #0A0A0A;
  }

  .prose-program :global(p) {
    color: #666666;
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .prose-program :global(ul) {
    color: #666666;
    line-height: 1.8;
    padding-left: 0;
    list-style: none;
  }

  .prose-program :global(li) {
    margin-bottom: 0.75rem;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .prose-program :global(strong) {
    color: #0A0A0A;
    font-weight: 600;
  }
</style>

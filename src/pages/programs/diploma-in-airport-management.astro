---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';

const program = {
  title: 'Diploma in Airport Management',
  subtitle: 'Aviation',
  duration: '1 Year',
  studyHours: '300 Hours',
  semesters: '2 Semesters',
  eligibility: '12th Standard',
  overview: `Get access to one of the top aviation management courses in Bangalore. This course is for students starting a career or wishing to expand their knowledge in aviation management. Students can start with the essentials to launch a career in the airline industry.`,
  courseFormat: `This course is available in printed Textbook format. This course requires approximately 300 hours of study, to be completed in 2 Semesters, 6 months each.`,
  learningObjectives: [
    'Understand the history of aviation and the role airports play in the economy',
    'Discover the various airport customers and partners',
    'Gain knowledge about operational and business functions of airports',
    'Know the history, scale and scope of the airline industry',
    'Learn passenger and baggage check-in and boarding procedures',
    'Ensure safe and secure passenger and baggage transport',
    'Provide superior customer service in demanding environments',
    'Learn about the latest technological innovations in passenger services',
  ],
  subjects: [
    { code: 'CE01', name: 'Communicative English', theory: 50, practical: 50, total: 100 },
    { code: 'AV01', name: 'Introduction to Aviation', theory: 100, practical: '-', total: 100 },
    { code: 'AV02', name: 'Airline Customer Service', theory: 100, practical: '-', total: 100 },
    { code: 'AV03', name: 'Airline & Airport Management', theory: 100, practical: '-', total: 100 },
    { code: 'AV04', name: 'Aviation Safety & Security', theory: 50, practical: 50, total: 100 },
    { code: 'AV05', name: 'Load Planning & Dangerous Goods', theory: 50, practical: 50, total: 100 },
  ],
  totalMarks: 600,
  recommendedFor: [
    'Entry-level airline industry staff',
    'Newcomers to the airline industry',
    'Airline passenger service staff',
    'Ground Handling Agents',
    'Airport operators\' staff',
    'Travel industry staff',
  ],
  includes: 'Personality Development, Grooming & Interview Skills',
};

const otherPrograms = [
  { name: 'Diploma in Cabin Crew & Airport Ground Operations', slug: 'diploma-in-cabin-crew' },
  { name: 'Certification Course in Airline Customer Service', slug: 'certification-in-airline-customer-service' },
  { name: 'Corporate Training', slug: 'corporate-training' },
];
---

<Layout 
  title={`${program.title} | Vervve Academy`}
  description="Learn airport management with our 1-year diploma program. Master aviation operations, customer service, safety & security. Enroll now for a career in aviation."
>
  <Navbar />
  
  <main>
    <article class="bg-white">
      <header class="max-w-3xl mx-auto px-6 pt-16 pb-10">
        <a href="/#programs" class="inline-flex items-center gap-2 text-muted text-sm hover:text-ink transition-colors mb-8">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Programs
        </a>
        
        <div class="flex items-center gap-4 mb-6">
          <span class="text-[11px] font-medium uppercase tracking-widest text-muted">
            {program.subtitle}
          </span>
          <span class="text-muted">·</span>
          <span class="text-muted text-sm">{program.duration}</span>
        </div>
        
        <h1 class="font-sans font-normal text-3xl md:text-4xl lg:text-5xl text-ink tracking-tight leading-[1.3] lg:leading-[1.3] mb-6">
          {program.title}
        </h1>
        
        <p class="text-muted text-lg leading-relaxed mb-8">
          {program.overview}
        </p>
        
        <div class="flex flex-wrap gap-8 pb-8 border-b border-border">
          <div class="text-left">
            <p class="text-xl font-semibold text-ink">{program.duration}</p>
            <p class="text-xs text-muted mt-1">Duration</p>
          </div>
          <div class="text-left">
            <p class="text-xl font-semibold text-ink">{program.studyHours}</p>
            <p class="text-xs text-muted mt-1">Study Hours</p>
          </div>
          <div class="text-left">
            <p class="text-xl font-semibold text-ink">{program.semesters}</p>
            <p class="text-xs text-muted mt-1">Semesters</p>
          </div>
          <div class="text-left">
            <p class="text-xl font-semibold text-ink">{program.eligibility}</p>
            <p class="text-xs text-muted mt-1">Eligibility</p>
          </div>
        </div>
      </header>

      <div class="max-w-3xl mx-auto px-6 pb-12">
        <div class="prose-program space-y-20">
          <section>
            <h2>Course Format</h2>
            <p>{program.courseFormat}</p>
          </section>

          <section>
            <h2>What You'll Learn</h2>
            <ul>
              {program.learningObjectives.map((objective) => (
                <li>
                  <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{objective}</span>
                </li>
              ))}
            </ul>
          </section>

          <section>
            <h2>Syllabus</h2>
            <div class="overflow-x-auto -mx-6 px-6">
              <table class="w-full text-sm min-w-[500px]">
                <thead class="bg-off-white/50">
                  <tr>
                    <th class="text-left py-3 px-4 font-medium text-ink text-xs uppercase tracking-wider">Code</th>
                    <th class="text-left py-3 px-4 font-medium text-ink text-xs uppercase tracking-wider">Subject</th>
                    <th class="text-center py-3 px-3 font-medium text-ink text-xs uppercase tracking-wider">Theory</th>
                    <th class="text-center py-3 px-3 font-medium text-ink text-xs uppercase tracking-wider">Prac</th>
                    <th class="text-center py-3 px-3 font-medium text-ink text-xs uppercase tracking-wider">Total</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-border">
                  {program.subjects.map((subject) => (
                    <tr class="hover:bg-off-white/30 transition-colors">
                      <td class="py-3 px-4 text-muted font-mono text-xs">{subject.code}</td>
                      <td class="py-3 px-4 text-ink font-medium">{subject.name}</td>
                      <td class="py-3 px-3 text-center text-muted">{subject.theory}</td>
                      <td class="py-3 px-3 text-center text-muted">{subject.practical}</td>
                      <td class="py-3 px-3 text-center text-ink font-semibold">{subject.total}</td>
                    </tr>
                  ))}
                </tbody>
                <tfoot class="bg-off-white/50">
                  <tr class="border-t-2 border-border">
                    <td colspan="2" class="py-3 px-4 font-semibold text-ink text-sm">Total Marks</td>
                    <td class="py-3 px-3 text-center"></td>
                    <td class="py-3 px-3 text-center"></td>
                    <td class="py-3 px-3 text-center font-bold text-ink">{program.totalMarks}</td>
                  </tr>
                </tfoot>
              </table>
            </div>
          </section>

          <section>
            <h2>Also Included</h2>
            <p>This course includes dedicated sessions for <strong>{program.includes}</strong></p>
          </section>

          <section>
            <h2>Ideal For</h2>
            <ul>
              {program.recommendedFor.map((item) => (
                <li>
                  <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </section>
        </div>
      </div>

      <div class="max-w-3xl mx-auto px-6 pb-16">
        <div class="bg-off-white/50 rounded-2xl p-6 sm:p-8 flex flex-col gap-6">
          <div>
            <h3 class="text-2xl font-semibold text-ink mb-1 sm:mb-2">Ready to Enroll?</h3>
            <p class="text-muted text-sm">Take the first step towards your aviation career.</p>
          </div>
          <a href="/#contact" class="self-start sm:self-end bg-ink text-white text-base font-medium px-6 py-3 rounded-full hover:bg-zinc-700 transition-colors">
            Apply Now
          </a>
        </div>
      </div>
    </article>

    <section class="bg-off-white py-20 px-6">
      <div class="max-w-6xl mx-auto">
        <h2 class="font-sans font-normal text-2xl md:text-3xl text-ink tracking-tight leading-[1.4] mb-10">
          Other Programs
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {otherPrograms.map((p) => (
            <a href={`/programs/${p.slug}`} class="group">
              <article class="bg-white rounded-2xl overflow-hidden border border-border h-full flex flex-col">
                <div class="aspect-[16/10] bg-ink/5 flex items-center justify-center">
                  <svg class="w-10 h-10 text-ink/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                  </svg>
                </div>
                <div class="p-6 flex flex-col flex-1">
                  <h3 class="font-sans font-medium text-base text-ink leading-snug mb-3 group-hover:text-muted transition-colors">
                    {p.name}
                  </h3>
                  <span class="text-sm text-muted mt-auto inline-flex items-center gap-1">
                    Learn more
                    <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </span>
                </div>
              </article>
            </a>
          ))}
        </div>
      </div>
    </section>

    <CTA />
  </main>

  <Footer />
</Layout>

<style>
  .prose-program :global(h2) {
    font-family: 'Figtree', system-ui, sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: #0A0A0A;
    margin-bottom: 1rem;
    line-height: 1.4;
  }

  .prose-program :global(p) {
    color: #666666;
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .prose-program :global(ul) {
    color: #666666;
    line-height: 1.8;
    padding-left: 0;
    list-style: none;
  }

  .prose-program :global(li) {
    margin-bottom: 0.75rem;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .prose-program :global(strong) {
    color: #0A0A0A;
    font-weight: 600;
  }
</style>

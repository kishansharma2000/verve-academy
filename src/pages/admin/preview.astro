---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="CMS Preview">
  <div class="min-h-screen bg-zinc-100 p-8">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-2xl font-bold text-ink mb-8">CMS Preview — Blog & Events Dashboard</h1>
      
      <div class="space-y-8">
        <!-- Blog Section -->
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <h2 class="text-lg font-semibold text-ink mb-4 flex items-center gap-2">
            <span class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center text-blue-600">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
              </svg>
            </span>
            Blog Posts
          </h2>
          
          <div class="space-y-3">
            <div class="flex items-center gap-4 p-4 bg-zinc-50 rounded-lg">
              <div class="w-16 h-12 bg-zinc-200 rounded object-cover"></div>
              <div class="flex-1">
                <p class="font-medium text-ink">How to Become a Commercial Pilot in India</p>
                <p class="text-sm text-muted">Career Guide · 8 min read</p>
              </div>
              <span class="px-2 py-1 bg-green-100 text-green-700 text-xs rounded">Published</span>
            </div>
            
            <div class="flex items-center gap-4 p-4 bg-zinc-50 rounded-lg">
              <div class="w-16 h-12 bg-zinc-200 rounded object-cover"></div>
              <div class="flex-1">
                <p class="font-medium text-ink">Cabin Crew vs Ground Staff</p>
                <p class="text-sm text-muted">Career Guide · 6 min read</p>
              </div>
              <span class="px-2 py-1 bg-green-100 text-green-700 text-xs rounded">Published</span>
            </div>
            
            <div class="flex items-center gap-4 p-4 bg-zinc-50 rounded-lg">
              <div class="w-16 h-12 bg-zinc-200 rounded object-cover"></div>
              <div class="flex-1">
                <p class="font-medium text-ink">Aviation Industry Trends 2026</p>
                <p class="text-sm text-muted">Industry Insights · 7 min read</p>
              </div>
              <span class="px-2 py-1 bg-yellow-100 text-yellow-700 text-xs rounded">Featured</span>
            </div>
          </div>
          
          <button class="mt-4 w-full py-2 border-2 border-dashed border-zinc-300 rounded-lg text-zinc-500 hover:border-zinc-400 hover:text-zinc-600 transition-colors">
            + Add New Post
          </button>
        </div>
        
        <!-- Events Section -->
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <h2 class="text-lg font-semibold text-ink mb-4 flex items-center gap-2">
            <span class="w-8 h-8 bg-purple-100 rounded-lg flex items-center justify-center text-purple-600">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </span>
            Events
          </h2>
          
          <div class="space-y-3">
            <div class="flex items-center gap-4 p-4 bg-zinc-50 rounded-lg">
              <div class="w-16 h-12 bg-zinc-200 rounded object-cover"></div>
              <div class="flex-1">
                <p class="font-medium text-ink">Open House Day 2026</p>
                <p class="text-sm text-muted">April 25, 2026 · Bangalore</p>
              </div>
              <span class="px-2 py-1 bg-blue-100 text-blue-700 text-xs rounded">Featured</span>
            </div>
            
            <div class="flex items-center gap-4 p-4 bg-zinc-50 rounded-lg">
              <div class="w-16 h-12 bg-zinc-200 rounded object-cover"></div>
              <div class="flex-1">
                <p class="font-medium text-ink">Aviation Career Fair 2026</p>
                <p class="text-sm text-muted">May 15, 2026 · Airport</p>
              </div>
              <span class="px-2 py-1 bg-blue-100 text-blue-700 text-xs rounded">Featured</span>
            </div>
            
            <div class="flex items-center gap-4 p-4 bg-zinc-50 rounded-lg">
              <div class="w-16 h-12 bg-zinc-200 rounded object-cover"></div>
              <div class="flex-1">
                <p class="font-medium text-ink">Pilot Training Workshop</p>
                <p class="text-sm text-muted">June 10, 2026 · Academy</p>
              </div>
              <span class="px-2 py-1 bg-zinc-100 text-zinc-600 text-xs rounded">Draft</span>
            </div>
          </div>
          
          <button class="mt-4 w-full py-2 border-2 border-dashed border-zinc-300 rounded-lg text-zinc-500 hover:border-zinc-400 hover:text-zinc-600 transition-colors">
            + Add New Event
          </button>
        </div>
        
        <!-- Media Section -->
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <h2 class="text-lg font-semibold text-ink mb-4 flex items-center gap-2">
            <span class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center text-green-600">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </span>
            Media Library
          </h2>
          
          <div class="grid grid-cols-4 gap-3">
            <div class="aspect-square bg-zinc-200 rounded-lg"></div>
            <div class="aspect-square bg-zinc-200 rounded-lg"></div>
            <div class="aspect-square bg-zinc-200 rounded-lg"></div>
            <div class="aspect-square bg-zinc-200 rounded-lg flex items-center justify-center text-zinc-400">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

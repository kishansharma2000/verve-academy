---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';

export async function getStaticPaths() {
  const allPosts = await Astro.glob('../../content/blog/*.md');
  return allPosts.map((post) => ({
    params: { 
      slug: post.frontmatter.title.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')
    },
    props: { post }
  }));
}

const { post } = Astro.props;
const { title, description, pubDate, author, category, readTime, image } = post.frontmatter;

const allPosts = await Astro.glob('../../content/blog/*.md');
const relatedPosts = allPosts
  .filter(p => p.frontmatter.title !== title)
  .slice(0, 3);
---

<Layout title={`${title} — Vervve Academy`}>
  <Navbar />
  
  <main>
    <article class="bg-white">
      <header class="max-w-3xl mx-auto px-6 pt-16 pb-12">
        <a href="/blog" class="inline-flex items-center gap-2 text-muted text-sm hover:text-ink transition-colors mb-8">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Blog
        </a>
        
        <div class="flex items-center gap-4 mb-6">
          <span class="text-[11px] font-medium uppercase tracking-widest text-muted">
            {category}
          </span>
          <span class="text-muted">·</span>
          <span class="text-muted text-sm">{readTime}</span>
        </div>
        
        <h1 class="font-sans font-normal text-3xl md:text-4xl lg:text-5xl text-ink tracking-tight leading-[1.3] lg:leading-[1.3] mb-6">
          {title}
        </h1>
        
        <p class="text-muted text-lg leading-relaxed mb-8">
          {description}
        </p>
        
        <div class="flex items-center gap-4 pb-8 border-b border-border">
          <div class="w-10 h-10 rounded-full bg-off-white flex items-center justify-center text-sm font-medium text-ink">
            {author.charAt(0)}
          </div>
          <div>
            <p class="text-sm font-medium text-ink">{author}</p>
            <p class="text-sm text-muted">{new Date(pubDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</p>
          </div>
        </div>
      </header>

      <div class="max-w-3xl mx-auto px-6">
        <figure class="mb-12 rounded-2xl overflow-hidden">
          <img 
            src={image} 
            alt={title}
            class="w-full aspect-[16/9] object-cover"
          />
        </figure>
      </div>

      <div class="max-w-3xl mx-auto px-6 pb-24">
        <div class="prose-blog">
          <slot />
        </div>
      </div>
    </article>

    {relatedPosts.length > 0 && (
      <section class="bg-off-white py-20 px-6">
        <div class="max-w-6xl mx-auto">
          <h2 class="font-sans font-normal text-2xl md:text-3xl text-ink tracking-tight leading-[1.4] mb-10">
            Related Articles
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {relatedPosts.map((p) => (
              <a href={`/blog/${p.frontmatter.title.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}`} class="group">
                <article class="bg-white rounded-2xl overflow-hidden border border-border h-full flex flex-col">
                  <div class="aspect-[16/10] overflow-hidden">
                    <img 
                      src={p.frontmatter.image} 
                      alt={p.frontmatter.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    />
                  </div>
                  <div class="p-6 flex flex-col flex-1">
                    <span class="text-[11px] font-medium uppercase tracking-widest text-muted mb-3">
                      {p.frontmatter.category}
                    </span>
                    <h3 class="font-sans font-medium text-base text-ink leading-snug mb-3 group-hover:text-muted transition-colors line-clamp-2">
                      {p.frontmatter.title}
                    </h3>
                    <p class="text-sm text-muted mt-auto">
                      {new Date(p.frontmatter.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                    </p>
                  </div>
                </article>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <CTA />
  </main>

  <Footer />
</Layout>

<style>
  .prose-blog :global(h2) {
    font-family: 'Figtree', system-ui, sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: #0A0A0A;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.4;
  }

  .prose-blog :global(h3) {
    font-family: 'Figtree', system-ui, sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: #0A0A0A;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .prose-blog :global(p) {
    color: #666666;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .prose-blog :global(ul), .prose-blog :global(ol) {
    color: #666666;
    line-height: 1.8;
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .prose-blog :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose-blog :global(strong) {
    color: #0A0A0A;
    font-weight: 600;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

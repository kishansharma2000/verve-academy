---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';

export async function getStaticPaths() {
  const allEvents = await Astro.glob('../../content/events/*.md');
  return allEvents.map((event) => ({
    params: { 
      slug: event.frontmatter.title.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')
    },
    props: { event }
  }));
}

const { event } = Astro.props;
const { title, date, time, location, description, image, registerUrl } = event.frontmatter;

const allEvents = await Astro.glob('../../content/events/*.md');
const relatedEvents = allEvents
  .filter(e => e.frontmatter.title !== title && new Date(e.frontmatter.date) >= new Date())
  .slice(0, 3);
---

<Layout title={`${title} — Vervve Academy`}>
  <Navbar />
  
  <main>
    <article class="bg-white">
      <div class="max-w-3xl mx-auto px-6 pt-16 pb-12">
        <a href="/events" class="inline-flex items-center gap-2 text-muted text-sm hover:text-ink transition-colors mb-8">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Events
        </a>
        
        <div class="flex flex-wrap gap-4 text-muted text-sm mb-6">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            {new Date(date).toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' })}
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {time}
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            {location}
          </span>
        </div>
        
        <h1 class="font-sans font-normal text-3xl md:text-4xl lg:text-5xl text-ink tracking-tight leading-[1.3] mb-6">
          {title}
        </h1>
        
        <p class="text-muted text-lg leading-relaxed mb-8">
          {description}
        </p>
      </div>

      <div class="max-w-3xl mx-auto px-6">
        <figure class="mb-12 rounded-2xl overflow-hidden">
          <img 
            src={image} 
            alt={title}
            class="w-full aspect-[16/9] object-cover"
          />
        </figure>
      </div>

      <div class="max-w-3xl mx-auto px-6 pb-24">
        <div class="prose-blog">
          <slot />
        </div>

        {registerUrl && registerUrl !== "#register" && (
          <div class="mt-12 pt-8 border-t border-border">
            <a 
              href={registerUrl}
              class="inline-flex items-center gap-2 bg-ink text-white font-medium px-8 py-3.5 rounded-full hover:bg-zinc-700 transition-colors"
            >
              Register for this Event
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        )}
      </div>
    </article>

    {relatedEvents.length > 0 && (
      <section class="bg-off-white py-20 px-6">
        <div class="max-w-6xl mx-auto">
          <h2 class="font-sans font-normal text-2xl md:text-3xl text-ink tracking-tight leading-[1.4] mb-10">
            More Upcoming Events
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {relatedEvents.map((e) => (
              <a href={`/events/${e.frontmatter.title.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}`} class="group">
                <article class="bg-white rounded-2xl overflow-hidden border border-border h-full flex flex-col">
                  <div class="aspect-[16/10] overflow-hidden">
                    <img 
                      src={e.frontmatter.image} 
                      alt={e.frontmatter.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    />
                  </div>
                  <div class="p-6 flex flex-col flex-1">
                    <span class="text-[11px] font-medium uppercase tracking-widest text-muted mb-3">
                      {new Date(e.frontmatter.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                    </span>
                    <h3 class="font-sans font-medium text-base text-ink leading-snug mb-3 group-hover:text-muted transition-colors line-clamp-2">
                      {e.frontmatter.title}
                    </h3>
                    <p class="text-sm text-muted mt-auto">
                      {e.frontmatter.location}
                    </p>
                  </div>
                </article>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <CTA />
  </main>

  <Footer />
</Layout>

<style>
  .prose-blog :global(h2) {
    font-family: 'Figtree', system-ui, sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: #0A0A0A;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.4;
  }

  .prose-blog :global(h3) {
    font-family: 'Figtree', system-ui, sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: #0A0A0A;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .prose-blog :global(p) {
    color: #666666;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .prose-blog :global(ul), .prose-blog :global(ol) {
    color: #666666;
    line-height: 1.8;
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .prose-blog :global(li) {
    margin-bottom: 0.5rem;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

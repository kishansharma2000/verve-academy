---
---

<section class="bg-white">
  <div class="w-full px-6 py-6 md:py-24 relative lg:min-h-[100vh] lg:flex lg:items-center">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-2 lg:gap-12 items-center max-w-6xl mx-auto">

      <div class="text-center md:text-left order-2 lg:order-1 lg:pt-32">
        <h1 class="font-sans font-normal text-4xl sm:text-5xl md:text-6xl lg:text-7xl tracking-tighter text-ink leading-[1.1]">
          Chart Your Course.{' '}
          <br />
          <span class="text-aviation">Own the Sky.</span>
        </h1>

        <p class="text-muted text-sm sm:text-base font-normal leading-relaxed mt-4 sm:mt-6 max-w-md mx-auto md:mx-0">
          Vervve Academy trains the next generation of aviation professionals
          from first flight to airline-ready.
        </p>

        <div class="flex flex-wrap gap-4 mt-8 md:justify-start justify-center">
          <a href="#programs" class="btn-aviation inline-flex items-center gap-2">
            Explore Programs
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>

      <div class="hidden lg:block lg:absolute lg:left-[45%] lg:top-0 lg:w-[50%]">
        <img 
          src="/Hero-desktop.webp" 
          alt="Vervve Academy Aviation Training" 
          class="w-full h-[750px] object-contain"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="1600"
          height="750"
        />
      </div>
      
      <div class="lg:hidden">
        <img 
          src="/Hero-mobile.webp" 
          alt="Vervve Academy Aviation Training" 
          class="w-full h-[250px] object-contain"
          loading="lazy"
          decoding="async"
          width="800"
          height="250"
        />
      </div>

    </div>
  </div>
</section>

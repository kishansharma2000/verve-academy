---
---

<section class="bg-white">
  <div class="w-full px-6 py-6 md:py-24 relative lg:min-h-[100vh] lg:flex lg:items-center">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-2 lg:gap-12 items-center max-w-6xl mx-auto">

      <div class="text-center md:text-left order-2 lg:order-1 lg:pt-32">
        <p class="label mb-5">Bangalore · Yelahanka · Madikeri · Trichy</p>

        <h1 class="font-sans font-light text-[2.25rem] leading-[1.4] sm:text-[2.75rem] md:text-5xl lg:text-[2.75rem] xl:text-[3.25rem] tracking-[-0.025em] text-ink">
          Top Aviation Training Academy in{' '}
          <span class="text-aviation font-medium">Bangalore</span>
          <span class="block mt-3 font-medium text-aviation text-[1.125rem] sm:text-xl md:text-2xl lg:text-lg xl:text-xl tracking-tight">
            Cabin Crew &amp; Airport Management Courses
          </span>
        </h1>

        <p class="text-muted text-base md:text-lg leading-relaxed mt-6 max-w-xl mx-auto md:mx-0">
          DGCA-aligned aviation training with 1,200+ airline placements and partnerships with 30+ airlines across India and abroad.
        </p>

        <div class="flex flex-wrap gap-4 mt-8 md:justify-start justify-center">
          <a href="#programs" class="inline-flex items-center gap-2 font-semibold text-sm px-8 py-3.5 rounded-full transition-colors hover:opacity-90" style={{ backgroundColor: '#1A6CB4', color: '#FFFFFF', letterSpacing: '0.02em' }}>
            Enroll in Aviation Courses
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
          <a href="#contact" class="inline-block font-semibold text-sm px-8 py-3.5 rounded-full border transition-colors hover:bg-ink hover:text-white" style={{ borderColor: '#C8D2E0', color: '#0B1F45', letterSpacing: '0.02em' }}>Book Free Counseling</a>
        </div>
      </div>

      <div class="hidden lg:block lg:absolute lg:left-[45%] lg:top-0 lg:w-[55%]">
        <img
          src="/Hero-desktop.webp"
          alt="Vervve Academy Aviation Training"
          width="1200"
          height="750"
          class="w-full h-[750px] object-contain"
          fetchpriority="high"
        />
      </div>

      <div class="lg:hidden">
        <img
          src="/Hero-mobile.webp"
          alt="Vervve Academy Aviation Training"
          width="400"
          height="300"
          class="w-full h-auto object-contain"
          fetchpriority="high"
        />
      </div>

    </div>
  </div>
</section>

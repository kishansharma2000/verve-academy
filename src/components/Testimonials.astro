---
const testimonials = [
  {
    quote:
      "Vervve transformed my career completely. The cabin crew training was incredibly realistic with actual aircraft simulators and emergency drills. Within 2 months of completing my course, I received my offer letter from IndiGo.",
    name: "Rohit P Haibatti",
    program: "Cabin Crew · IndiGo Airlines",
    batch: "2025",
    avatar: "https://i.pravatar.cc/80?img=12",
  },
  {
    quote:
      "I joined Vervve right after my 12th with zero knowledge about airport operations. The 12-month Airport Management program covered everything from GDS systems to aviation security. Today I'm proudly working at BIAL.",
    name: "Sachin Karera G",
    program: "Airport Ops · Bangalore Airport",
    batch: "2024",
    avatar: "https://i.pravatar.cc/80?img=33",
  },
  {
    quote:
      "The 6-month Customer Service course was perfect for me. Training was intense but practical — from ticketing systems to handling difficult passengers. I'm now working with Air India at Bangalore airport.",
    name: "Mohammed Khalid K R",
    program: "Customer Service · Air India",
    batch: "2025",
    avatar: "https://i.pravatar.cc/80?img=15",
  },
  {
    quote:
      "Vervve gave me wings to fly internationally! The grooming sessions, personality development, and safety training were world-class. Now I'm based in Doha serving passengers from around the world with Qatar Airways.",
    name: "Nimisha Bhargav",
    program: "Cabin Crew · Qatar Airways",
    batch: "2024",
    avatar: "https://i.pravatar.cc/80?img=20",
  },
];
---

<section class="bg-white py-28">
  <div class="max-w-6xl mx-auto px-6 mb-20">
    <div class="flex justify-between items-start">
      <div>
        <p class="label mb-6">STUDENT STORIES</p>
        <h2 class="font-sans font-medium text-2xl md:text-3xl lg:text-4xl text-ink tracking-tight lg:leading-[1.3]">
          From Our Graduates
        </h2>
      </div>
      <p class="hidden md:block text-muted text-sm text-right leading-relaxed">
        Hear from the people<br />who've been there.
      </p>
    </div>
  </div>

  <div class="relative -mx-6">
    <div class="absolute left-0 top-0 bottom-0 w-16 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none" />
    <div class="absolute right-0 top-0 bottom-0 w-16 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none" />
    <div class="overflow-hidden">
      <div class="flex gap-6 marquee-track">
        {[...testimonials, ...testimonials].map((t, i) => (
          <div
            key={`${t.name}-${i}`}
            class="flex-shrink-0 w-[280px] sm:w-[320px] md:w-[380px] bg-off-white p-6 md:p-8 border border-border rounded-2xl"
          >
            <p class="font-sans font-medium text-base md:text-lg text-ink leading-relaxed mb-8 break-words">
              {t.quote}
            </p>
            <div class="flex items-center gap-4">
              <img
                src={t.avatar}
                alt={t.name}
                class="w-14 h-14 object-cover rounded-full"
              />
              <div>
                <p class="font-medium text-ink text-sm">{t.name}</p>
                <p class="text-[11px] uppercase tracking-widest text-muted mt-1">
                  {t.program} &middot; Batch {t.batch}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

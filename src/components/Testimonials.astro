---
const testimonials = [
  {
    quote:
      "Vervve didn't just give me a license — they gave me a career. The faculty treated us like professionals from day one.",
    name: "Aryan Mehta",
    program: "CPL",
    batch: "2023",
    avatar: "https://i.pravatar.cc/80?img=1",
  },
  {
    quote:
      "The placement support was incredible. I had my first airline interview within 3 months of completing my CPL.",
    name: "Priya Sinha",
    program: "CPL",
    batch: "2023",
    avatar: "https://i.pravatar.cc/80?img=2",
  },
  {
    quote:
      "Best decision I ever made. The simulator hours alone are worth it — you feel like a real pilot before you even solo.",
    name: "Rahul Nair",
    program: "PPL",
    batch: "2024",
    avatar: "https://i.pravatar.cc/80?img=3",
  },
];
---

<section class="bg-white py-28">
  <div class="max-w-6xl mx-auto px-6 mb-20">
    <div class="flex justify-between items-start">
      <div>
        <p class="label mb-6">STUDENT STORIES</p>
        <h2 class="font-sans font-normal text-4xl md:text-5xl lg:text-6xl text-ink tracking-tight lg:leading-[1.3]">
          From Our Graduates
        </h2>
      </div>
      <p class="hidden md:block text-muted text-sm text-right leading-relaxed">
        Hear from the people<br />who've been there.
      </p>
    </div>
  </div>

  <div class="relative -mx-6">
    <div class="absolute left-0 top-0 bottom-0 w-16 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none" />
    <div class="absolute right-0 top-0 bottom-0 w-16 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none" />
    <div class="overflow-hidden">
      <div class="flex gap-6 marquee-track">
        {[...testimonials, ...testimonials].map((t, i) => (
          <div
            key={`${t.name}-${i}`}
            class="flex-shrink-0 w-[280px] sm:w-[320px] md:w-[380px] bg-off-white p-6 md:p-8 border border-border rounded-2xl"
          >
            <p class="font-sans font-normal text-base md:text-lg text-ink leading-relaxed mb-8 break-words">
              {t.quote}
            </p>
            <div class="flex items-center gap-4">
              <img
                src={t.avatar}
                alt={t.name}
                class="w-14 h-14 object-cover rounded-full"
              />
              <div>
                <p class="font-medium text-ink text-sm">{t.name}</p>
                <p class="text-[11px] uppercase tracking-widest text-muted mt-1">
                  {t.program} &middot; Batch {t.batch}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

---
const stats = [
  { number: "2,000+", label: "Students Trained" },
  { number: "95%", label: "Placement Rate" },
  { number: "50+", label: "Airline Partners" },
  { number: "15+", label: "Years" },
];
---

<section class="py-28 px-6" style={{ backgroundColor: '#0A0A0A' }}>
  <div class="max-w-6xl mx-auto">

    <div class="grid grid-cols-2 md:flex mb-16 gap-8 md:gap-0 md:divide-x divide-white/10">
      {stats.map((stat, index) => (
        <div class={`text-center px-4 py-6 ${index % 2 === 0 ? 'border-r border-white/10' : ''} md:flex-1 md:border-0`}>
          <div class="font-sans font-normal text-white text-5xl sm:text-6xl md:text-8xl leading-[1.5] tracking-tighter">
            {stat.number}
          </div>
          <div class="text-[11px] uppercase tracking-widest text-white/40 mt-2 md:mt-3">
            {stat.label}
          </div>
        </div>
      ))}
    </div>

    <p class="font-sans font-normal text-white text-2xl md:text-4xl max-w-2xl mx-auto text-center leading-[1.5]">
      &ldquo;We don&rsquo;t just teach aviation.<br />We build careers.&rdquo;
    </p>

  </div>
</section>

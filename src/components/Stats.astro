---
const stats = [
  { number: "15+", label: "Years Experience" },
  { number: "500+", label: "Students Placed" },
  { number: "4", label: "Expert Courses" },
  { number: "350+", label: "Placements" },
];
---

<section class="py-20 px-6" style={{ backgroundColor: '#0A0A0A' }}>
  <div class="max-w-6xl mx-auto">

    <div class="flex flex-wrap justify-center gap-12 md:gap-24 mb-16">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="font-sans font-normal text-white text-5xl md:text-8xl leading-[1.2] tracking-tighter">
            {stat.number}
          </div>
          <div class="text-[11px] uppercase tracking-widest text-white/40 mt-2">
            {stat.label}
          </div>
        </div>
      ))}
    </div>

    <p class="font-sans font-normal text-white text-2xl md:text-4xl max-w-2xl mx-auto text-center leading-[1.6]">
      &ldquo;We don&rsquo;t just teach aviation.<br />We build careers.&rdquo;
    </p>

  </div>
</section>

---
const faqs = [
  {
    question: 'What is the minimum qualification required for aviation courses at Vervve Academy?',
    answer: 'The minimum qualification is 10+2 (Higher Secondary) or equivalent from any recognized board. For cabin crew training, additional physical requirements include minimum height (155cm for females, 170cm for males), clear skin, good eyesight, and ability to swim. Graduates are preferred for airport management and flight operations programs.',
  },
  {
    question: 'How long are the aviation courses and what is the fee structure?',
    answer: 'Diploma in Airport Management: 12 months. Diploma in Cabin Crew & Ground Operations: 12 months. Certification in Airline Customer Service: 6 months. Flight Operations Training: 3-6 months (modular). Fees range from ₹75,000 to ₹2,50,000 depending on the program. We offer flexible EMI payment options and scholarships for meritorious students. Call +91-9620001901 for detailed fee information.',
  },
  {
    question: 'Who are these aviation courses recommended for?',
    answer: 'Our programs are ideal for recent 12th pass students seeking entry into airline and airport careers, graduates transitioning into aviation management, working professionals switching to aviation, and international students seeking DGCA-aligned training in India. Students from any academic background (Science, Commerce, Arts) can apply — no prior aviation experience required.',
  },
  {
    question: 'Does Vervve Academy provide placement assistance after course completion?',
    answer: 'Yes. Vervve offers 100% placement assistance with a 95% historical placement success rate. Our placement cell has partnerships with Air India, IndiGo, SpiceJet, Vistara, GoAir, Emirates, Qatar Airways, Etihad, and 25+ other airlines. We conduct on-campus recruitment drives, walk-in interviews, resume building, and interview coaching until students secure positions.',
  },
  {
    question: 'What is the difference between cabin crew and ground staff training?',
    answer: 'Cabin crew training prepares you for in-flight roles as flight attendants — focusing on passenger safety, emergency procedures, in-flight service, and aircraft operations. Ground staff training focuses on airport-based roles including check-in operations, ticketing, baggage handling, and customer service at airport terminals. Our Diploma in Cabin Crew & Ground Operations covers both skill sets comprehensively.',
  },
  {
    question: 'Are the courses recognized by aviation authorities in India?',
    answer: 'Yes. Our curriculum is aligned with DGCA (Directorate General of Civil Aviation) guidelines and international aviation standards. Our diplomas and certifications are recognized by major airlines and airport operators across India. We also maintain partnerships with REVA University for degree-level aviation management programs.',
  },
  {
    question: 'What are the age limits for cabin crew training?',
    answer: 'Most airlines prefer candidates between 18-27 years for cabin crew positions at the time of training. Age limits may vary by airline — some international carriers accept candidates up to 30 years. Contact our counselors for specific airline requirements.',
  },
  {
    question: 'Can I pursue aviation courses while working or studying?',
    answer: 'Yes. We offer weekend and evening batches for our 6-month Airline Customer Service certification program — suitable for working professionals and college students. Full-time diploma programs (12 months) require weekday attendance for practical training sessions.',
  },
];
---

<section class="bg-off-white py-28 px-6">
  <div class="max-w-3xl mx-auto">

    <div class="mb-20">
      <p class="label mb-6">FAQ</p>
      <h2 class="font-sans font-medium text-2xl md:text-3xl lg:text-4xl text-ink tracking-tight lg:leading-[1.3]">
        Frequently Asked Questions About Aviation Courses in Bangalore
      </h2>
    </div>

    <ul id="faq-list" class="space-y-4">
      {faqs.map((faq, index) => (
        <li key={index} class="faq-item bg-white rounded-2xl p-6">
          <button class="faq-toggle w-full flex items-center justify-between gap-4 text-left">
            <span class="font-sans font-medium text-ink text-lg md:text-xl leading-snug">
              {faq.question}
            </span>
            <span class="faq-icon text-muted text-2xl shrink-0">+</span>
          </button>
          <p class="faq-answer hidden text-muted text-base font-normal leading-relaxed mt-4">
            {faq.answer}
          </p>
        </li>
      ))}
    </ul>

  </div>
</section>

<script>
  const faqItems = document.querySelectorAll('.faq-item');
  let openIndex: number | null = null;

  faqItems.forEach((item, index) => {
    const toggle = item.querySelector('.faq-toggle');
    const answer = item.querySelector('.faq-answer');
    const icon = item.querySelector('.faq-icon');

    toggle?.addEventListener('click', () => {
      if (openIndex === index) {
        answer?.classList.add('hidden');
        if (icon) icon.textContent = '+';
        openIndex = null;
      } else {
        faqItems.forEach((i, idx) => {
          const a = i.querySelector('.faq-answer');
          const ic = i.querySelector('.faq-icon');
          if (idx === index) {
            a?.classList.remove('hidden');
            if (ic) ic.textContent = '−';
          } else {
            a?.classList.add('hidden');
            if (ic) ic.textContent = '+';
          }
        });
        openIndex = index;
      }
    });
  });
</script>

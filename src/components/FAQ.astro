---
const faqs = [
  {
    question: 'What are the eligibility requirements for pilot training?',
    answer: 'Candidates must be at least 17 years old with a minimum of 50% marks in Physics and Mathematics in their 12th standard. A valid Class 2 medical certificate is also required.',
  },
  {
    question: 'How long does it take to become a commercial pilot?',
    answer: 'The complete CPL program takes approximately 12-18 months, depending on weather conditions and individual flight training progress.',
  },
  {
    question: 'What is the total cost of pilot training?',
    answer: 'The cost varies based on the program chosen. We offer flexible payment plans and scholarship options. Contact our admissions team for a detailed fee structure.',
  },
  {
    question: 'Do you provide placement assistance?',
    answer: 'Yes, we have a dedicated placement cell with partnerships with 50+ airlines. Our placement rate stands at 95% within 6 months of course completion.',
  },
  {
    question: 'Can I get financial assistance or loans?',
    answer: 'We partner with leading banks for education loans. Additionally, we offer scholarships for meritorious students and those from economically weaker sections.',
  },
];
---

<section class="bg-off-white py-28 px-6">
  <div class="max-w-3xl mx-auto">

    <div class="mb-20">
      <p class="label mb-6">FAQ</p>
      <h2 class="font-sans font-normal text-4xl md:text-5xl lg:text-6xl text-ink tracking-tight lg:leading-[1.3]">
        Frequently Asked Questions
      </h2>
    </div>

    <ul id="faq-list" class="space-y-4">
      {faqs.map((faq, index) => (
        <li key={index} class="faq-item bg-white rounded-2xl p-6">
          <button class="faq-toggle w-full flex items-center justify-between gap-4 text-left">
            <span class="font-sans font-medium text-ink text-lg md:text-xl leading-snug">
              {faq.question}
            </span>
            <span class="faq-icon text-muted text-2xl shrink-0">+</span>
          </button>
          <p class="faq-answer hidden text-muted text-base font-normal leading-relaxed mt-4">
            {faq.answer}
          </p>
        </li>
      ))}
    </ul>

  </div>
</section>

<script>
  const faqItems = document.querySelectorAll('.faq-item');
  let openIndex: number | null = null;

  faqItems.forEach((item, index) => {
    const toggle = item.querySelector('.faq-toggle');
    const answer = item.querySelector('.faq-answer');
    const icon = item.querySelector('.faq-icon');

    toggle?.addEventListener('click', () => {
      if (openIndex === index) {
        answer?.classList.add('hidden');
        if (icon) icon.textContent = '+';
        openIndex = null;
      } else {
        faqItems.forEach((i, idx) => {
          const a = i.querySelector('.faq-answer');
          const ic = i.querySelector('.faq-icon');
          if (idx === index) {
            a?.classList.remove('hidden');
            if (ic) ic.textContent = '−';
          } else {
            a?.classList.add('hidden');
            if (ic) ic.textContent = '+';
          }
        });
        openIndex = index;
      }
    });
  });
</script>

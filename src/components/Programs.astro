---
const programs = [
  {
    number: '01',
    name: 'Diploma in Airport Management',
    slug: 'diploma-in-airport-management',
    duration: '12 Months',
    description:
      'A comprehensive airport management course in Bangalore covering airport operations, ground handling, aviation safety & security (BCAS), GDS training (Amadeus, Galileo, Sabre), and customer service excellence.',
  },
  {
    number: '02',
    name: 'Diploma in Cabin Crew & Airport Ground Operations',
    slug: 'diploma-in-cabin-crew',
    duration: '12 Months',
    description:
      'Launch your career as a professional flight attendant. Real aircraft cabin mock-ups, in-flight emergency procedures, safety equipment training, grooming, and interview preparation with airline recruiters.',
  },
  {
    number: '03',
    name: 'Certification Course in Airline Customer Service',
    slug: 'certification-in-airline-customer-service',
    duration: '6 Months',
    description:
      'Master frontline airline customer service, ticketing operations, check-in & boarding procedures, and computer reservation systems (Amadeus / Galileo) — designed for quick employment at airports and airlines.',
  },
  {
    number: '04',
    name: 'Flight Operations & Aviation Management',
    slug: 'corporate-training',
    duration: '3-6 Months',
    description:
      'Specialized training in flight dispatch, crew resource management (CRM), aviation meteorology, aircraft performance, and safety management systems — for supervisory and management roles in airlines.',
  },
];
---

<section class="bg-white py-28 px-6">
  <div class="max-w-6xl mx-auto">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-20 gap-6">
      <div>
        <p class="label mb-6">AVIATION COURSES IN BANGALORE</p>
        <h2 class="font-sans font-medium text-2xl md:text-3xl lg:text-4xl text-ink tracking-tight lg:leading-[1.3] max-w-2xl">
          Diploma &amp; Certification Programs
        </h2>
      </div>
      <p class="text-muted text-sm leading-relaxed max-w-xs md:text-right">
        Specialized aviation training designed to launch your career in airlines, airports, and aviation management — across India and internationally.
      </p>
    </div>

    <div class="border-t border-border">
      {programs.map((program) => (
        <a
          href={`/programs/${program.slug}`}
          class="group border-b border-border py-8 flex items-start gap-8 cursor-pointer no-underline"
        >
          <span class="text-[11px] font-bold tracking-[0.28em] mt-1 w-8 shrink-0" style={{ color: '#E8A020' }}>
            {program.number}
          </span>

          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-baseline gap-x-3 gap-y-2">
              <span class="text-xl md:text-2xl font-normal text-ink group-hover:text-aviation transition-colors duration-200">
                {program.name}
              </span>
              <span class="border border-border text-muted text-[10px] px-2 py-0.5 uppercase tracking-widest inline-block shrink-0">
                {program.duration}
              </span>
            </div>
            <p class="text-muted text-sm mt-2 max-w-lg leading-relaxed">
              {program.description}
            </p>
          </div>

          <span class="text-aviation text-lg mt-1 shrink-0 group-hover:translate-x-1 transition-transform duration-200">
            &rarr;
          </span>
        </a>
      ))}
    </div>

  </div>
</section>

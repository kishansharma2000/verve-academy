---
const features = [
  {
    id: "01",
    title: "DGCA Approved",
    description:
      "Fully certified by India's aviation authority. Your license recognized nationwide.",
    image: "https://images.unsplash.com/photo-1436491865332-7a61a109cc05?w=900&q=80",
  },
  {
    id: "02",
    title: "Modern Fleet & Simulators",
    description:
      "Industry-standard aircraft and full-motion simulators used by commercial airlines.",
    image: "https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=900&q=80",
  },
  {
    id: "03",
    title: "Expert Faculty",
    description:
      "Learn from active commercial pilots and seasoned industry veterans.",
    image: "https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=900&q=80",
  },
  {
    id: "04",
    title: "100% Placement Assistance",
    description:
      "Dedicated career cell with direct airline connections.",
    image: "https://images.unsplash.com/photo-1521737711867-e3b97375f902?w=900&q=80",
  },
  {
    id: "05",
    title: "International Exposure",
    description:
      "Exchange programs and globally recognized certifications.",
    image: "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=900&q=80",
  },
];
---

<section class="bg-off-white py-28 px-6">
  <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16">

    <div>
      <p class="label mb-4">WHY VERVE</p>
      <h2 class="font-sans font-normal text-2xl md:text-3xl lg:text-4xl text-ink tracking-tight lg:leading-[1.3] mb-8">
        Training That Goes Beyond<br class="hidden lg:block" /> the Classroom
      </h2>

      <ul id="features-list" class="space-y-2">
        {features.map((feature, index) => (
          <li 
            key={feature.id} 
            data-index={index}
            class="bg-white rounded-[12px] overflow-hidden cursor-pointer transition-shadow"
          >
            <button
              class="w-full py-7 px-6 flex items-start gap-6 text-left"
            >
              <span class="text-[11px] font-medium text-muted tracking-widest shrink-0 mt-0.5">
                {feature.id}
              </span>
              <div class="flex-1">
                <p class="font-sans font-medium text-ink text-base">
                  {feature.title}
                </p>
                <p class="feature-desc text-muted text-sm mt-2 leading-relaxed hidden">
                  {feature.description}
                </p>
              </div>
              <span class="feature-icon text-muted text-xl shrink-0">
                +
              </span>
            </button>
          </li>
        ))}
      </ul>
    </div>

    <div class="lg:sticky lg:top-24 lg:self-start lg:h-[640px] rounded-[12px] overflow-hidden">
      <div id="features-images" class="relative w-full h-full">
        {features.map((feature, index) => (
          <img
            key={feature.id}
            data-index={index}
            src={feature.image}
            alt={feature.title}
            class="feature-img absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-0"
          />
        ))}
      </div>
    </div>

  </div>
</section>

<script>
  const featuresList = document.getElementById('features-list');
  const featureItems = featuresList?.querySelectorAll('li');
  const featureImages = document.querySelectorAll('.feature-img');
  const featureDescs = document.querySelectorAll('.feature-desc');
  const featureIcons = document.querySelectorAll('.feature-icon');
  let activeIndex = 0;

  function setActive(index: number) {
    activeIndex = index;
    
    featureImages.forEach((img, i) => {
      img.classList.toggle('opacity-100', i === index);
      img.classList.toggle('opacity-0', i !== index);
    });

    featureItems?.forEach((item, i) => {
      if (i === index) {
        item.classList.add('shadow-sm');
      } else {
        item.classList.remove('shadow-sm');
      }
    });

    featureDescs.forEach((desc, i) => {
      if (i === index) {
        desc.classList.remove('hidden');
      } else {
        desc.classList.add('hidden');
      }
    });

    featureIcons.forEach((icon, i) => {
      icon.textContent = i === index ? '−' : '+';
    });
  }

  featureItems?.forEach((item, index) => {
    item.addEventListener('click', () => setActive(index));
  });

  setActive(0);

  setInterval(() => {
    setActive((activeIndex + 1) % 5);
  }, 5000);
</script>

---
const features = [
  {
    id: "01",
    title: "DGCA-Aligned Curriculum",
    description:
      "Aviation management and cabin crew programs designed around DGCA guidelines and international aviation safety standards.",
  },
  {
    id: "02",
    title: "State-of-the-Art Training Facilities",
    description:
      "Aircraft cabin mock-ups, safety equipment simulators, fire-fighting and emergency evacuation modules at our Yelahanka, Bangalore campus.",
  },
  {
    id: "03",
    title: "Industry-Expert Faculty",
    description:
      "Certified trainers with 10+ years of airline experience across cabin crew operations, airport management, and aviation customer service.",
  },
  {
    id: "04",
    title: "100% Placement Assistance",
    description:
      "Direct partnerships with Air India, IndiGo, SpiceJet, Vistara, Emirates, Qatar Airways and 25+ domestic and international airlines.",
  },
  {
    id: "05",
    title: "Multi-Location Presence",
    description:
      "Training centers in Bangalore (Yelahanka), Madikeri, and Trichy serving students across South India.",
  },
];
---

<section class="bg-off-white py-28 px-6">
  <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16">

    <div>
      <p class="label mb-4">WHY VERVVE</p>
      <h2 class="font-sans font-medium text-2xl md:text-3xl lg:text-4xl text-ink tracking-tight lg:leading-[1.3] mb-8">
        Why Vervve is the Best<br class="hidden lg:block" /> Aviation Academy in Bangalore
      </h2>

      <ul id="features-list" class="space-y-2">
        {features.map((feature, index) => (
          <li 
            key={feature.id} 
            data-index={index}
            class="bg-white rounded-[12px] overflow-hidden cursor-pointer transition-shadow"
          >
            <button
              class="w-full py-7 px-6 flex items-start gap-6 text-left"
            >
              <span class="text-[11px] font-bold tracking-[0.28em] shrink-0 mt-0.5" style={{ color: '#E8A020' }}>
                {feature.id}
              </span>
              <div class="flex-1">
                <p class="font-sans font-medium text-ink text-base">
                  {feature.title}
                </p>
                <p class="feature-desc text-muted text-sm mt-2 leading-relaxed hidden">
                  {feature.description}
                </p>
              </div>
              <span class="feature-icon text-aviation text-xl shrink-0">
                +
              </span>
            </button>
          </li>
        ))}
      </ul>
    </div>

    <div class="lg:sticky lg:top-24 lg:self-start lg:h-[640px] rounded-[12px] overflow-hidden relative" style={{ backgroundColor: '#0B1F45' }}>
      <div class="absolute inset-0 flex items-center justify-center">
        <img src="/logo.svg" alt="" class="w-40 opacity-30" />
      </div>
      <div class="absolute bottom-0 left-0 right-0 p-8">
        <p class="text-[11px] uppercase tracking-[0.28em] font-bold" style={{ color: '#E8A020' }}>The Ascent Mark</p>
        <p class="text-white/85 text-sm mt-2 leading-relaxed">A crown of ambition. A compass of precision. Every Vervve graduate carries it forward.</p>
      </div>
    </div>

  </div>
</section>

<script>
  const featuresList = document.getElementById('features-list');
  const featureItems = featuresList?.querySelectorAll('li');
  const featureDescs = document.querySelectorAll('.feature-desc');
  const featureIcons = document.querySelectorAll('.feature-icon');

  function setActive(index: number) {
    featureItems?.forEach((item, i) => {
      if (i === index) {
        item.classList.add('shadow-sm', 'ring-2', 'ring-aviation/20');
      } else {
        item.classList.remove('shadow-sm', 'ring-2', 'ring-aviation/20');
      }
    });

    featureDescs.forEach((desc, i) => {
      if (i === index) {
        desc.classList.remove('hidden');
      } else {
        desc.classList.add('hidden');
      }
    });

    featureIcons.forEach((icon, i) => {
      icon.textContent = i === index ? '−' : '+';
    });
  }

  featureItems?.forEach((item, index) => {
    item.addEventListener('click', () => setActive(index));
  });

  setActive(0);
</script>

---

<section class="py-32 px-6" style={{ backgroundColor: '#0066CC' }}>
  <div class="max-w-3xl mx-auto text-center">

    <p class="text-[11px] uppercase tracking-widest text-white/40">
      TAKE THE FIRST STEP
    </p>

    <h2 class="font-sans font-normal text-white text-4xl md:text-5xl lg:text-6xl tracking-tighter lg:leading-[1.3] mt-4">
      Ready to Fly?<br />Let's Get You There.
    </h2>

    <div class="border-t border-white/10 my-10 max-w-xs mx-auto" />

    <p class="text-white/50 text-base max-w-md mx-auto">
      Applications open for the 2025–26 batch. Limited seats.
    </p>

    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="#apply"
        class="bg-white text-[#0066CC] font-medium px-8 py-3.5 text-sm hover:bg-gray-100 transition-colors rounded-full"
      >
        Apply Now
      </a>
      <a
        href="#contact"
        class="border border-white text-white font-medium px-8 py-3.5 text-sm hover:bg-white hover:text-[#0066CC] transition-colors rounded-full"
      >
        Talk to a Counsellor
      </a>
    </div>

  </div>
</section>

---
---

<section id="apply" class="py-24 px-6 relative overflow-hidden" style={{ backgroundColor: '#0B1F45' }}>
  <!-- Gold accent rule (≤10% visual weight) -->
  <div class="absolute top-0 left-0 right-0 h-[3px]" style={{ backgroundColor: '#E8A020' }}></div>

  <div class="max-w-3xl mx-auto text-center relative z-10">

    <p class="text-[11px] uppercase tracking-[0.28em] font-semibold" style={{ color: '#E8A020' }}>
      Take the first step
    </p>

    <h2 class="font-sans font-medium text-white text-4xl md:text-5xl lg:text-6xl tracking-[-0.03em] leading-[1.05] mt-5">
      Ready to fly?<br />
      <span class="font-medium" style={{ color: '#5BA8E5' }}>Let's get you there.</span>
    </h2>

    <p class="text-white/75 text-base md:text-lg max-w-md mx-auto mt-6 leading-relaxed">
      Applications open for the 2025–26 batch. Limited seats. Industry-certified. Placement supported.
    </p>

    <div class="mt-12 flex flex-wrap gap-4 justify-center">
      <a href="#contact" class="inline-block font-semibold text-base md:text-lg px-10 py-4 rounded-full transition-colors" style={{ backgroundColor: '#E8A020', color: '#0B1F45', letterSpacing: '0.01em' }}>
        Apply Now
      </a>
      <a href="tel:+919620001901" class="inline-block font-semibold text-base md:text-lg px-10 py-4 rounded-full border-[1.5px] border-white/50 text-white hover:bg-white hover:text-ink transition-colors" style={{ letterSpacing: '0.01em' }}>
        +91 96200 01901
      </a>
    </div>

  </div>
</section>

---
---

<section class="py-20 px-6 relative overflow-hidden" style={{ backgroundColor: '#0066CC' }}>
  <div class="absolute inset-0 opacity-20 pointer-events-none">
    <div class="absolute top-8 left-8 w-40 h-40 border border-white rounded-full animate-pulse"></div>
    <div class="absolute top-32 right-12 w-24 h-24 bg-white/20 rounded-full animate-pulse" style="animation-duration: 3s;"></div>
    <div class="absolute bottom-16 left-1/4 w-20 h-20 border-2 border-white/30 rounded-full animate-pulse" style="animation-delay: 0.5s; animation-duration: 2s;"></div>
    <div class="absolute bottom-8 right-1/3 w-32 h-32 border border-white/20 rounded-full animate-pulse" style="animation-delay: 1s; animation-duration: 2.5s;"></div>
    <div class="absolute top-1/2 left-1/3 w-16 h-16 bg-white/10 rounded-full animate-pulse" style="animation-delay: 0.3s; animation-duration: 3s;"></div>
    <div class="absolute top-16 right-1/2 w-12 h-12 bg-white/10 rounded-full animate-pulse" style="animation-delay: 0.7s;"></div>
  </div>
  <div class="max-w-3xl mx-auto text-center relative z-10">

    <p class="text-[11px] uppercase tracking-widest text-white/40">
      TAKE THE FIRST STEP
    </p>

    <h2 class="font-sans font-normal text-white text-4xl md:text-5xl lg:text-6xl tracking-tighter lg:leading-[1.3] mt-4">
      Ready to Fly?<br />Let's Get You There.
    </h2>

    <p class="text-white/50 text-base max-w-md mx-auto mt-8">
      Applications open for the 2025–26 batch. Limited seats.
    </p>

    <div class="mt-10">
      <a
        href="#apply"
        class="inline-block bg-white text-[#0066CC] font-medium px-10 py-4 text-base hover:bg-gray-100 transition-colors rounded-full"
      >
        Apply Now
      </a>
    </div>

  </div>
</section>
